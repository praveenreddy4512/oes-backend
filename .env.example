PORT=5000
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=online_exam_db

# ==========================================
# EMAIL/SMTP CONFIGURATION
# ==========================================
# 
# Choose ONE of the email service options below:
# 
# OPTION 1: GMAIL (Recommended for testing)
# ========================================
# 1. Enable 2-Step Verification on your Google Account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate an "App Password" for Mail
# 4. Copy the 16-character password below (without spaces)
# 
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password-16-characters

# 
# OPTION 2: OUTLOOK/OFFICE365
# ============================
# Uncomment below and set your Outlook credentials
# EMAIL_SERVICE=outlook
# EMAIL_USER=your-email@outlook.com or your-email@company.com
# EMAIL_PASSWORD=your-password

# 
# OPTION 3: CUSTOM SMTP PROVIDER
# ===============================
# (e.g., SendGrid, Mailgun, AWS SES, or self-hosted server)
# Uncomment below and configure your SMTP details
# EMAIL_SERVICE=custom
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# EMAIL_USER=your-email@example.com
# EMAIL_PASSWORD=your-password

# Frontend URL for email links (password reset, etc)
FRONTEND_URL=http://localhost:5173

# Session and JWT secrets
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
SESSION_SECRET=your-super-secret-session-key-change-this-in-production
SESSION_PATH=./sessions

# ==========================================
# EMAIL FEATURES
# ==========================================
# 
# When email is configured, the system will send:
# 
# 1. EXAM SUBMISSION CONFIRMATION (to student)
#    - Sent when student submits their exam
#    - Includes: exam name, score, percentage
# 
# 2. EXAM COMPLETION REPORT (to professor)
#    - Sent when exam end time is reached
#    - Includes: total students, submitted count, average score, top 3 performers
# 
# 3. PASSWORD RESET EMAIL
#    - Sent when user requests password reset
#    - Includes: secure reset link (expires in 1 hour)
# 
# 4. PASSWORD CHANGED CONFIRMATION
#    - Sent after password is successfully reset
# 
# ==========================================
# CONFIGURATION EXAMPLES
# ==========================================
# 
# GMAIL EXAMPLE:
# EMAIL_SERVICE=gmail
# EMAIL_USER=testuser@gmail.com
# EMAIL_PASSWORD=abcd efgh ijkl mnop
# 
# SENDGRID EXAMPLE:
# EMAIL_SERVICE=custom
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# EMAIL_USER=apikey
# EMAIL_PASSWORD=SG.xxxxxxxxxxxxxxxxxxxxx
#
# AWS SES EXAMPLE:
# EMAIL_SERVICE=custom
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_SECURE=false
# EMAIL_USER=your-ses-username
# EMAIL_PASSWORD=your-ses-password
# 
# LOCAL TESTING (no emails sent):
# Leave EMAIL_USER and EMAIL_PASSWORD empty
# Emails will be logged but not actually sent
# 
